---
import { getEntry, render } from "astro:content";
import MainGridLayout from "../../layouts/MainGridLayout.astro";

const aboutPost = await getEntry("spec", "about-en");

if (!aboutPost) {
	throw new Error("English about page content not found");
}

const { Content } = await render(aboutPost);
---

<MainGridLayout title="About" lang="en">
	<div class="card-base rounded-[var(--radius-large)] px-6 md:px-9 pt-6 pb-4">
		<div class="markdown-content">
			<Content />
		</div>
	</div>
</MainGridLayout>

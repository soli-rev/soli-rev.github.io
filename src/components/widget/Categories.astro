---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getCategoryList } from "../../utils/content-utils";
import { isEnglishPostLang } from "../../utils/url-utils";
import ButtonLink from "../control/ButtonLink.astro";
import WidgetLayout from "./WidgetLayout.astro";

const COLLAPSED_HEIGHT = "7.5rem";
const COLLAPSE_THRESHOLD = 5;

interface Props {
	class?: string;
	style?: string;
	lang?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
const lang = Astro.props.lang;
const isEnglish = isEnglishPostLang(lang);
const categories = await getCategoryList(isEnglish ? "en" : "zh");
const isCollapsed = categories.length >= COLLAPSE_THRESHOLD;
---

<WidgetLayout name={i18n(I18nKey.categories, lang)} id="categories" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT}
                class={className} style={style}
                lang={lang}
>
    {categories.map((c) =>
        <ButtonLink
            url={c.url}
            badge={String(c.count)}
            label={isEnglish ? `View all posts in the ${c.name.trim()} category` : `查看 ${c.name.trim()} 分类下的全部文章`}
        >
            {c.name.trim()}
        </ButtonLink>
    )}
</WidgetLayout>
